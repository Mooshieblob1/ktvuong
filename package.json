{
	"name": "ktvuong",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=20.19.0",
		"pnpm": ">=10.32.1"
	},
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
